#include <reg51.h>

#define msec 10

unsigned int arr[10]={0x40,0xF9,0x24,0x30,0x19,0x12,0x02,0xF8,0x00,0x10};

sbit d3=P1^1;   // minute tens 
sbit d2=P1^2;   // minute units
sbit d1=P1^3;   // second tens
sbit d0=P1^4;   // second units

unsigned int v0,v1,v2,v3,v4;

void delay(unsigned int count)
{
unsigned int j,k;
for(j=0;j<=count;j++)
for(k=0;k<=5;k++);
}

void main()
{
v0=v1=v2=v3=v4=0;

while(1)
{

v0++;

if(v0==130)     // create 1 second delay
{
v0=0;
v1++;           // second unit
}

if(v1==10)
{
v1=0;
v2++;           // second tens
}

if(v2==6)
{
v2=0;
v3++;           // minute units
}

if(v3==10)
{
v3=0;
v4++;           // minute tens
}

if(v4==6)       // reset after 59 minutes
{
v4=0;
v3=0;
v2=0;
v1=0;
}

P2=0xFF;
d0=1; d1=d2=d3=0;
P2=arr[v1];
delay(msec);

P2=0xFF;
d1=1; d0=d2=d3=0;
P2=arr[v2];
delay(msec);

P2=0xFF;
d2=1; d0=d1=d3=0;
P2=arr[v3];
delay(msec);

P2=0xFF;
d3=1; d0=d1=d2=0;
P2=arr[v4];
delay(msec);

}

} 

